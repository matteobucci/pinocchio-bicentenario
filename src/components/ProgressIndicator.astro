---
/**
 * ProgressIndicator - Visual progress through the 12 stations
 *
 * Displays "Tappa X di 12" with clickable dots for navigation.
 * Fully accessible with keyboard navigation and screen reader support.
 */

interface Station {
  id: string;
  data: {
    title: string;
    order: number;
  };
}

interface Props {
  currentStation: number;
  stations: Station[];
}

const { currentStation, stations } = Astro.props;

// Sort stations by order
const sortedStations = [...stations].sort((a, b) => a.data.order - b.data.order);
const totalStations = sortedStations.length;
---

<nav
  class="progress-indicator"
  role="navigation"
  aria-label="Progresso del percorso"
>
  <div class="progress-label">
    <span class="visually-hidden">Sei alla </span>
    <span class="progress-current">Tappa {currentStation}</span>
    <span class="progress-total"> di {totalStations}</span>
  </div>

  <div
    class="progress-dots"
    role="list"
    aria-label="Vai a una tappa specifica"
  >
    {sortedStations.map((station) => {
      const isCurrent = station.data.order === currentStation;
      const slug = station.id.replace(/\.md$/, '');
      return (
        <a
          href={`/tappe/${slug}`}
          class:list={["progress-dot", { current: isCurrent }]}
          role="listitem"
          aria-label={`Vai alla tappa ${station.data.order}: ${station.data.title}`}
          aria-current={isCurrent ? "step" : undefined}
          data-order={station.data.order}
        >
          <span class="dot-number">{station.data.order}</span>
        </a>
      );
    })}
  </div>
</nav>

<style>
  .progress-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-6) var(--space-4);
    background: var(--color-neutral-50);
    border-radius: var(--border-radius-lg);
  }

  .progress-label {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-medium);
    color: var(--color-neutral-700);
  }

  .progress-current {
    color: var(--color-primary-600);
    font-weight: var(--font-weight-bold);
  }

  .progress-total {
    color: var(--color-neutral-500);
  }

  .progress-dots {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: center;
  }

  .progress-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--border-radius-full);
    border: var(--border-width-2) solid var(--color-neutral-300);
    background: white;
    color: var(--color-neutral-500);
    text-decoration: none;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    transition: all var(--transition-fast);
    cursor: pointer;
  }

  .progress-dot:hover {
    border-color: var(--color-primary-300);
    background: var(--color-primary-50);
    color: var(--color-primary-600);
    transform: scale(1.1);
  }

  .progress-dot:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .progress-dot.current {
    border-color: var(--color-primary-500);
    background: var(--color-primary-500);
    color: white;
    font-weight: var(--font-weight-bold);
  }

  .progress-dot.current:hover {
    background: var(--color-primary-600);
    border-color: var(--color-primary-600);
    color: white;
  }

  .dot-number {
    line-height: 1;
  }

  /* Responsive: smaller dots on mobile */
  @media (max-width: 480px) {
    .progress-dot {
      width: 28px;
      height: 28px;
      font-size: var(--font-size-xs);
    }

    .progress-dots {
      gap: var(--space-1);
    }
  }

  /* Visually hidden but accessible to screen readers */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
</style>

<script>
  // Keyboard navigation for progress dots
  document.addEventListener('DOMContentLoaded', () => {
    const dots = document.querySelectorAll('.progress-dot');

    dots.forEach((dot, index) => {
      dot.addEventListener('keydown', (e) => {
        const event = e as KeyboardEvent;
        let targetIndex = index;

        switch (event.key) {
          case 'ArrowRight':
          case 'ArrowDown':
            event.preventDefault();
            targetIndex = (index + 1) % dots.length;
            break;
          case 'ArrowLeft':
          case 'ArrowUp':
            event.preventDefault();
            targetIndex = (index - 1 + dots.length) % dots.length;
            break;
          case 'Home':
            event.preventDefault();
            targetIndex = 0;
            break;
          case 'End':
            event.preventDefault();
            targetIndex = dots.length - 1;
            break;
          default:
            return;
        }

        (dots[targetIndex] as HTMLElement).focus();
      });
    });
  });
</script>
