---
/**
 * TourMap - Interactive Leaflet map showing all 12 stations
 *
 * Displays stations as numbered markers with a walking path connecting them.
 * Fully accessible with text alternative and keyboard support.
 */

interface Station {
  id: string;
  data: {
    title: string;
    order: number;
    directions?: {
      coordinates?: string;
      address: string;
    };
  };
}

/** A point of interest (toilet, water, rest area, parking) shown on the map. */
interface MapPoint {
  type: string;
  name: string;
  coordinates?: string;
  description?: string;
}

interface Props {
  stations: Station[];
  points?: MapPoint[];
  currentStation?: number;
  height?: string;
}

const { stations, points = [], currentStation, height = "400px" } = Astro.props;

// Visual + accessible metadata for each POI type. `emoji` is decorative;
// `label` is the text used by screen readers and the legend.
const POI_TYPES: Record<string, { emoji: string; label: string }> = {
  bagno: { emoji: "♿", label: "Bagno accessibile" },
  acqua: { emoji: "🚰", label: "Punto acqua" },
  sosta: { emoji: "🪑", label: "Area sosta" },
  parcheggio: { emoji: "🅿️", label: "Parcheggio accessibile" },
};

// Parse POIs that have valid coordinates so the script can place markers.
const poiData = points
  .filter((p) => p.coordinates && POI_TYPES[p.type])
  .map((p) => {
    const coords = p.coordinates!.split(",").map((c) => parseFloat(c.trim()));
    return {
      type: p.type,
      name: p.name,
      description: p.description || "",
      emoji: POI_TYPES[p.type].emoji,
      typeLabel: POI_TYPES[p.type].label,
      lat: coords[0],
      lng: coords[1],
    };
  })
  .filter((p) => !isNaN(p.lat) && !isNaN(p.lng));

// Which POI types are actually present — used to render the legend.
const legendTypes = Object.keys(POI_TYPES).filter((t) =>
  poiData.some((p) => p.type === t)
);

// Sort stations by order and extract coordinate data
const sortedStations = [...stations]
  .sort((a, b) => a.data.order - b.data.order)
  .filter(s => s.data.directions?.coordinates);

// Parse coordinates for each station
const stationData = sortedStations.map(station => {
  const coords = station.data.directions?.coordinates?.split(',').map(c => parseFloat(c.trim())) || [0, 0];
  const slug = station.id.replace(/\.md$/, '');
  return {
    id: station.id,
    slug: slug,
    title: station.data.title,
    order: station.data.order,
    lat: coords[0],
    lng: coords[1],
    address: station.data.directions?.address || '',
    isCurrent: station.data.order === currentStation
  };
});

// Calculate center point (fallback to Sesto Fiorentino if no coordinates available)
const hasCoordinates = stationData.length > 0;
const avgLat = hasCoordinates
  ? stationData.reduce((sum, s) => sum + s.lat, 0) / stationData.length
  : 43.8331;  // Sesto Fiorentino default
const avgLng = hasCoordinates
  ? stationData.reduce((sum, s) => sum + s.lng, 0) / stationData.length
  : 11.1989;
---

<div class="tour-map-container">
  {hasCoordinates ? (
    <div
      id="tour-map"
      class="tour-map"
      style={`height: ${height};`}
      role="application"
      aria-label="Mappa interattiva del percorso con le 12 tappe"
      tabindex="0"
      data-stations={JSON.stringify(stationData)}
      data-pois={JSON.stringify(poiData)}
      data-lat={avgLat}
      data-lng={avgLng}
    ></div>
  ) : (
    <div class="tour-map-placeholder" style={`min-height: ${height};`}>
      <p>
        🗺️ <strong>Mappa interattiva in arrivo.</strong><br />
        Nel frattempo, trovi l'elenco completo delle tappe qui sotto.
      </p>
    </div>
  )}

  {legendTypes.length > 0 && (
    <ul class="map-legend" aria-label="Legenda dei punti di servizio sulla mappa">
      {legendTypes.map((type) => (
        <li class="map-legend__item">
          <span class={`poi-icon poi-icon--${type}`} aria-hidden="true">
            {POI_TYPES[type].emoji}
          </span>
          <span>{POI_TYPES[type].label}</span>
        </li>
      ))}
    </ul>
  )}

  <!-- Service points text alternative — POI names/descriptions aren't conveyed
       by the map markers or legend, so this list is their only text equivalent.
       (The tappe themselves are listed in full on the page below the map.) -->
  {poiData.length > 0 && (
    <details class="map-text-alternative">
      <summary>Punti di servizio lungo il percorso</summary>
      <ul class="poi-list">
        {poiData.map((poi) => (
          <li>
            <strong>{poi.typeLabel}:</strong> {poi.name}
            {poi.description && (
              <>
                <br />
                <span class="station-address">{poi.description}</span>
              </>
            )}
          </li>
        ))}
      </ul>
    </details>
  )}
</div>

<style>
  .tour-map-container {
    width: 100%;
  }

  .tour-map {
    width: 100%;
    border-radius: var(--border-radius-lg);
    border: var(--border-width) solid var(--color-neutral-200);
  }

  .tour-map:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .map-text-alternative {
    margin-top: var(--space-4);
    padding: var(--space-3);
    background: var(--color-neutral-50);
    border-radius: var(--border-radius-md);
  }

  .map-text-alternative summary {
    cursor: pointer;
    font-weight: var(--font-weight-medium);
    color: var(--color-neutral-700);
    padding: var(--space-2);
  }

  .map-text-alternative summary:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-color);
    outline-offset: var(--focus-ring-offset);
  }

  .station-address {
    font-size: var(--font-size-sm);
    color: var(--color-neutral-500);
  }

  /* Custom marker styles */
  :global(.station-marker) {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 28px !important;
    height: 28px !important;
    border-radius: 50%;
    background: var(--color-primary-500);
    color: white;
    font-weight: bold;
    font-size: 12px;
    border: 3px solid white;
    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
    line-height: 1;
  }

  :global(.station-marker span) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  :global(.station-marker.current) {
    width: 36px !important;
    height: 36px !important;
    background: var(--color-secondary-500);
    font-size: 14px;
    border-width: 4px;
    z-index: 1000 !important;
  }

  :global(.station-marker:hover) {
    transform: scale(1.1);
  }

  /* POI (point of interest) markers */
  :global(.poi-marker) {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 30px !important;
    height: 30px !important;
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    background: white;
    border: 2px solid var(--color-neutral-300);
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.3);
  }

  :global(.poi-marker span) {
    transform: rotate(45deg);
    font-size: 15px;
    line-height: 1;
  }

  :global(.poi-marker--bagno) { border-color: var(--color-info); }
  :global(.poi-marker--acqua) { border-color: var(--color-secondary-500); }
  :global(.poi-marker--sosta) { border-color: var(--color-warning); }
  :global(.poi-marker--parcheggio) { border-color: var(--color-primary-500); }

  /* Legend below the map */
  .map-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: var(--space-3);
    background: var(--color-neutral-50);
    border-radius: var(--border-radius-md);
  }

  .map-legend__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-sm);
    color: var(--color-neutral-700);
  }

  .poi-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: white;
    border: 2px solid var(--color-neutral-300);
    font-size: 14px;
  }

  .poi-icon--bagno { border-color: var(--color-info); }
  .poi-icon--acqua { border-color: var(--color-secondary-500); }
  .poi-icon--sosta { border-color: var(--color-warning); }
  .poi-icon--parcheggio { border-color: var(--color-primary-500); }

  .poi-list {
    padding-left: var(--space-6);
  }

  .poi-list li {
    margin-bottom: var(--space-3);
    line-height: var(--line-height-relaxed);
  }

  :global(.leaflet-popup-content-wrapper) {
    border-radius: var(--border-radius-md);
  }

  :global(.leaflet-popup-content) {
    margin: var(--space-3);
    font-family: var(--font-family-base);
  }

  :global(.popup-content) {
    text-align: center;
  }

  :global(.popup-title) {
    font-weight: var(--font-weight-bold);
    color: var(--color-neutral-800);
    margin-bottom: var(--space-2);
  }

  :global(.leaflet-popup-content .popup-link),
  :global(.popup-link) {
    display: inline-block;
    margin-top: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: var(--color-primary-500) !important;
    color: white !important;
    text-decoration: none !important;
    border-radius: var(--border-radius-md);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  :global(.leaflet-popup-content .popup-link:hover),
  :global(.popup-link:hover) {
    background: var(--color-primary-600) !important;
    color: white !important;
  }
</style>

<script>
  // Leaflet is loaded as a global from <head>.
  declare const L: any;

  // Builds the interactive tour map. Runs on first load AND after every
  // client-side navigation (astro:page-load) — Leaflet is loaded in <head> so
  // `L` is always available. All per-page data is read from the #tour-map
  // element's data-* attributes, so each navigation gets fresh content with no
  // stale closures. The `mapReady` flag guards against re-initializing a node.
  function initTourMap() {
    const mapElement = document.getElementById('tour-map');
    if (!mapElement || typeof L === 'undefined') return;
    if (mapElement.dataset.mapReady === 'true') return;
    mapElement.dataset.mapReady = 'true';

    const stationData = JSON.parse(mapElement.dataset.stations || '[]');
    const poiData = JSON.parse(mapElement.dataset.pois || '[]');
    const avgLat = parseFloat(mapElement.dataset.lat || '') || 43.8331;
    const avgLng = parseFloat(mapElement.dataset.lng || '') || 11.1989;

    // Initialize map centered on the stations
    const map = L.map(mapElement, {
      center: [avgLat, avgLng],
      zoom: 14,
      scrollWheelZoom: false  // Prevent accidental zoom while scrolling
    });

    // Add CARTO Positron tiles — clean, light base so the route and markers stand out
    L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 20
    }).addTo(map);

    // Create custom icon for each station
    function createMarkerIcon(order: number, isCurrent: boolean) {
      return L.divIcon({
        className: `station-marker ${isCurrent ? 'current' : ''}`,
        html: `<span>${order}</span>`,
        iconSize: isCurrent ? [36, 36] : [28, 28],
        iconAnchor: isCurrent ? [18, 18] : [14, 14],
        popupAnchor: [0, isCurrent ? -20 : -16]
      });
    }

    // Add markers for each station
    const markers: any[] = [];
    const pathCoords: any[] = [];

    stationData.forEach((station: any) => {
      if (station.lat && station.lng) {
        pathCoords.push([station.lat, station.lng]);

        const marker = L.marker([station.lat, station.lng], {
          icon: createMarkerIcon(station.order, station.isCurrent),
          title: `Tappa ${station.order}: ${station.title}`,
          alt: `Tappa ${station.order}: ${station.title}`,
          keyboard: true
        }).addTo(map);

        // Create popup content
        const popupContent = `
          <div class="popup-content">
            <div class="popup-title">Tappa ${station.order}</div>
            <div>${station.title}</div>
            <a href="/tappe/${station.slug}" class="popup-link">Vai alla tappa</a>
          </div>
        `;

        marker.bindPopup(popupContent);
        markers.push(marker);
      }
    });

    // Draw path connecting stations
    if (pathCoords.length > 1) {
      // White casing underneath for contrast against the light base map
      L.polyline(pathCoords, {
        color: '#ffffff',
        weight: 13,
        opacity: 1,
        lineCap: 'round',
        lineJoin: 'round'
      }).addTo(map);

      // Bold solid route line on top
      const routeLine = L.polyline(pathCoords, {
        color: '#3d7d66',  // secondary-500
        weight: 8,
        opacity: 0.95,
        lineCap: 'round',
        lineJoin: 'round'
      }).addTo(map);

      // Clean triangular direction arrows repeated along the route (sense of travel).
      // Falls back gracefully to just the line if the plugin failed to load.
      if (L.polylineDecorator) {
        L.polylineDecorator(routeLine, {
          patterns: [
            {
              offset: 30,
              repeat: 90,
              symbol: L.Symbol.arrowHead({
                pixelSize: 11,
                headAngle: 50,
                polygon: true,
                pathOptions: {
                  stroke: false,
                  fillColor: '#ffffff',
                  fillOpacity: 0.95,
                },
              }),
            },
          ],
        }).addTo(map);
      }
    }

    // Add point-of-interest markers (toilets, water, rest areas, parking)
    poiData.forEach((poi: any) => {
      L.marker([poi.lat, poi.lng], {
        icon: L.divIcon({
          className: `poi-marker poi-marker--${poi.type}`,
          html: `<span>${poi.emoji}</span>`,
          iconSize: [30, 30],
          iconAnchor: [15, 30],
          popupAnchor: [0, -28],
        }),
        title: `${poi.typeLabel}: ${poi.name}`,
        alt: `${poi.typeLabel}: ${poi.name}`,
      })
        .addTo(map)
        .bindPopup(
          `<div class="popup-content">
            <div class="popup-title">${poi.typeLabel}</div>
            <div>${poi.name}</div>
            ${poi.description ? `<p>${poi.description}</p>` : ''}
          </div>`
        );
    });

    // Fit map to show all markers with padding
    if (markers.length > 0) {
      const group = L.featureGroup(markers);
      map.fitBounds(group.getBounds().pad(0.1));
    }

    // Enable scroll wheel zoom when map is focused
    mapElement.addEventListener('focus', () => {
      map.scrollWheelZoom.enable();
    });
    mapElement.addEventListener('blur', () => {
      map.scrollWheelZoom.disable();
    });

    // Keyboard navigation for markers
    let currentMarkerIndex = 0;
    mapElement.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Tab') return; // Allow normal tab behavior

      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        e.preventDefault();
        currentMarkerIndex = (currentMarkerIndex + 1) % markers.length;
        map.setView(markers[currentMarkerIndex].getLatLng(), map.getZoom());
        markers[currentMarkerIndex].openPopup();
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        e.preventDefault();
        currentMarkerIndex = (currentMarkerIndex - 1 + markers.length) % markers.length;
        map.setView(markers[currentMarkerIndex].getLatLng(), map.getZoom());
        markers[currentMarkerIndex].openPopup();
      } else if (e.key === 'Enter') {
        markers[currentMarkerIndex].openPopup();
      }
    });
  }

  // Run on initial load and after every client-side navigation. This module is
  // hoisted and executes once, so the listener is registered a single time;
  // the element-level `mapReady` guard prevents any double initialization.
  initTourMap();
  document.addEventListener('astro:page-load', initTourMap);
</script>
