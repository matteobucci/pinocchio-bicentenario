---
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Un viaggio in 12 tappe attraverso il mondo di Pinocchio, tra Firenze e Sesto Fiorentino" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#9a6b35" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Fredoka (rounded, friendly headings) + Atkinson Hyperlegible
         (body text designed by the Braille Institute for low-vision readers) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&family=Fredoka:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="it_IT" />

    <title>{title} | Pinocchio Bicentenario</title>

    <!-- Preload critical CSS -->
    <link rel="preload" href="/styles/global.css" as="style" />

    <!-- Leaflet (maps). Loaded once here — not per-component — so the library
         persists across client-side navigations and is guaranteed available
         before any map initializes on astro:page-load. is:inline keeps Astro
         from bundling these as ES modules (the plugin's UMD wrapper needs a
         classic-script `this`, otherwise it throws on `global.L`). -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />
    <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script is:inline src="https://unpkg.com/leaflet-polylinedecorator@1.6.0/dist/leaflet.polylineDecorator.js"></script>

    <!-- Client-side routing: navigations swap content without a full reload,
         so the persistent station drawer stays mounted and never rebuilds. -->
    <ClientRouter />

    <Analytics />
  </head>
  <body>
    <!-- Skip link for keyboard/screen reader users -->
    <a href="#main-content" class="skip-link">
      Vai al contenuto principale
    </a>

    <header class="site-header" role="banner">
      <nav class="nav container" aria-label="Navigazione principale">
        <a href="/" class="nav-logo" aria-label="Pinocchio Bicentenario - Torna alla home">
          <span class="logo-text">Pinocchio Bicentenario</span>
        </a>

        <ul class="nav-menu" role="list">
          <li>
            <a
              href="/"
              class:list={["nav-link", { active: currentPath === "/" }]}
              aria-current={currentPath === "/" ? "page" : undefined}
            >
              Home
            </a>
          </li>
          <li>
            <a
              href="/tappe"
              class:list={["nav-link", { active: currentPath.startsWith("/tappe") }]}
              aria-current={currentPath.startsWith("/tappe") ? "page" : undefined}
            >
              Le Tappe
            </a>
          </li>
          <li>
            <a
              href="/chi-siamo"
              class:list={["nav-link", { active: currentPath === "/chi-siamo" }]}
              aria-current={currentPath === "/chi-siamo" ? "page" : undefined}
            >
              Chi siamo
            </a>
          </li>
        </ul>

        <!-- Mobile menu button -->
        <button
          class="nav-toggle"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Apri menu di navigazione"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </nav>
    </header>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer" role="contentinfo">
      <div class="container">
        <div class="footer-content">
          <div class="footer-section">
            <h2 class="footer-title">Pinocchio Bicentenario</h2>
            <p class="footer-description">
              Un percorso accessibile per celebrare i 200 anni dalla nascita
              di Carlo Collodi, tra Firenze e Sesto Fiorentino.
            </p>
          </div>

          <div class="footer-section">
            <h3 class="footer-subtitle">Link rapidi</h3>
            <ul class="footer-links" role="list">
              <li><a href="/tappe">Tutte le tappe</a></li>
              <li><a href="/chi-siamo">Chi siamo</a></li>
              <li><a href="/accessibilita">Accessibilità</a></li>
            </ul>
          </div>

          <div class="footer-section">
            <h3 class="footer-subtitle">Il podcast</h3>
            <p class="footer-description">
              12 episodi con trascrizione completa, disponibili in ogni tappa del percorso.
            </p>
          </div>
        </div>

        <div class="footer-partners">
          <h3 class="footer-subtitle">Promosso da</h3>
          <ul class="partner-logos" role="list">
            <li>
              <a
                href="https://aidel22.it/"
                class="partner-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="AIdel22 — Associazione Italiana delezione del Cromosoma 22 APS (si apre in una nuova scheda)"
              >
                <img
                  src="/images/logo-associazione.png"
                  alt="AIdel22 — Associazione Italiana delezione del Cromosoma 22 APS"
                  class="partner-logo"
                  loading="lazy"
                />
              </a>
            </li>
            <li>
              <a
                href="https://webradio.aidel22.it/"
                class="partner-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Radio AIdel22 (si apre in una nuova scheda)"
              >
                <img
                  src="/images/partner-radio-aid.svg"
                  alt="Radio AIdel22"
                  class="partner-logo"
                  loading="lazy"
                />
              </a>
            </li>
            <li>
              <img
                src="/images/partner-terranova.png"
                alt="Terranova — software for sustainable cities"
                class="partner-logo"
                loading="lazy"
              />
            </li>
          </ul>
        </div>

        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} Pinocchio Bicentenario. Tutti i diritti riservati.</p>
          <p class="footer-a11y">
            Questo sito è stato realizzato con particolare attenzione all'accessibilità.
          </p>
        </div>
      </div>
    </footer>

    <style is:global>
      @import '../styles/global.css';
    </style>

    <style>
      /* Header */
      .site-header {
        background: white;
        box-shadow: var(--shadow-sm);
        position: sticky;
        top: 0;
        z-index: var(--z-sticky);
      }

      .nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: var(--space-4);
        padding-bottom: var(--space-4);
      }

      .nav-logo {
        text-decoration: none;
        color: var(--color-primary-600);
        font-weight: var(--font-weight-bold);
        font-size: var(--font-size-lg);
      }

      .nav-menu {
        display: flex;
        gap: var(--space-6);
        list-style: none;
        margin: 0;
        padding: 0;
      }

      .nav-link {
        color: var(--color-neutral-700);
        text-decoration: none;
        font-weight: var(--font-weight-medium);
        padding: var(--space-2) var(--space-3);
        border-radius: var(--border-radius-md);
        transition: all var(--transition-fast);
      }

      .nav-link:hover {
        color: var(--color-primary-600);
        background: var(--color-primary-50);
      }

      .nav-link.active {
        color: var(--color-primary-600);
        background: var(--color-primary-100);
      }

      .nav-toggle {
        display: none;
        flex-direction: column;
        gap: 4px;
        padding: var(--space-2);
      }

      .hamburger-line {
        width: 24px;
        height: 2px;
        background: var(--color-neutral-700);
        transition: all var(--transition-fast);
      }

      /* Footer */
      .site-footer {
        background: var(--color-neutral-900);
        color: var(--color-neutral-200);
        padding: var(--space-12) 0 var(--space-6);
        margin-top: var(--space-16);
      }

      .footer-content {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--space-8);
        margin-bottom: var(--space-8);
      }

      .footer-title {
        color: white;
        font-size: var(--font-size-xl);
        margin-bottom: var(--space-3);
      }

      .footer-subtitle {
        color: white;
        font-size: var(--font-size-base);
        margin-bottom: var(--space-3);
      }

      .footer-description {
        color: var(--color-neutral-400);
        font-size: var(--font-size-sm);
        line-height: var(--line-height-relaxed);
      }

      .footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
      }

      .footer-links li {
        margin-bottom: var(--space-2);
      }

      .footer-links a {
        color: var(--color-neutral-300);
        text-decoration: none;
        font-size: var(--font-size-sm);
        transition: color var(--transition-fast);
      }

      .footer-links a:hover {
        color: white;
      }

      .footer-partners {
        border-top: 1px solid var(--color-neutral-700);
        padding-top: var(--space-6);
        margin-bottom: var(--space-8);
        text-align: center;
      }

      .footer-partners .footer-subtitle {
        margin-bottom: var(--space-5);
      }

      .partner-logos {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: var(--space-8);
      }

      .partner-link {
        display: inline-flex;
        border-radius: var(--border-radius-md);
        transition: transform var(--transition-fast), opacity var(--transition-fast);
      }

      .partner-link:hover {
        transform: translateY(-2px);
        opacity: 0.9;
      }

      /* White plate so dark logos stay legible on the dark footer */
      .partner-logo {
        height: 56px;
        width: auto;
        max-width: 220px;
        object-fit: contain;
        background: white;
        padding: var(--space-2) var(--space-3);
        border-radius: var(--border-radius-md);
      }

      .footer-bottom {
        border-top: 1px solid var(--color-neutral-700);
        padding-top: var(--space-6);
        text-align: center;
        font-size: var(--font-size-sm);
        color: var(--color-neutral-400);
      }

      .footer-a11y {
        margin-top: var(--space-2);
        font-size: var(--font-size-xs);
      }

      /* Mobile styles */
      @media (max-width: 768px) {
        .nav-menu {
          display: none;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: white;
          flex-direction: column;
          padding: var(--space-4);
          box-shadow: var(--shadow-md);
        }

        .nav-menu.open {
          display: flex;
        }

        .nav-toggle {
          display: flex;
        }
      }
    </style>

    <!-- Mobile menu toggle script. The header is re-rendered on every
         client-side navigation (it isn't transition:persist), so binding must
         run on astro:page-load — a one-time bind would go stale after the first
         soft navigation and the menu button would stop responding. -->
    <script>
      function setupNavToggle() {
        const navToggle = document.querySelector('.nav-toggle');
        const navMenu = document.querySelector('.nav-menu');

        navToggle?.addEventListener('click', () => {
          const isExpanded = navToggle.getAttribute('aria-expanded') === 'true';
          navToggle.setAttribute('aria-expanded', (!isExpanded).toString());
          navMenu?.classList.toggle('open');

          // Update aria-label
          navToggle.setAttribute(
            'aria-label',
            isExpanded ? 'Apri menu di navigazione' : 'Chiudi menu di navigazione'
          );
        });
      }

      document.addEventListener('astro:page-load', setupNavToggle);
    </script>

    <SpeedInsights />
  </body>
</html>
