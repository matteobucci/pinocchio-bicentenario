---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const stations = await getCollection('stations', ({ data }) => data.published);
const sortedStations = stations.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Tutte le Stazioni"
  description="Esplora le 12 stazioni del percorso Pinocchio Bicentenario a Sesto Fiorentino"
>
  <div class="page-header">
    <div class="container">
      <h1>Le 12 Stazioni</h1>
      <p class="page-intro">
        Un percorso attraverso il mondo di Pinocchio. Ogni stazione racconta
        un capitolo della storia, accompagnato da un episodio del podcast.
      </p>
    </div>
  </div>

  <section class="stations-section" aria-label="Lista delle stazioni">
    <div class="container">
      <ol class="timeline" role="list" aria-label="Timeline delle stazioni">
        {sortedStations.map((station, index) => (
          <li class="timeline-item">
            <div class="timeline-marker" aria-hidden="true">
              <span>{station.data.order}</span>
            </div>
            <article class="timeline-content card">
              {station.data.heroImage && (
                <img
                  src={station.data.heroImage}
                  alt=""
                  class="timeline-image"
                  loading={index < 3 ? "eager" : "lazy"}
                />
              )}
              <div class="card-body">
                <h2 class="timeline-title">
                  <a href={`/stazioni/${station.id.replace(/\.md$/, '')}`}>
                    {station.data.title}
                  </a>
                </h2>
                <p class="timeline-description">{station.data.description}</p>

                {station.data.podcast && (
                  <div class="timeline-meta">
                    {station.data.podcast.episodeTitle && (
                      <span class="episode-title">
                        {station.data.podcast.episodeTitle}
                      </span>
                    )}
                    {station.data.podcast.duration && (
                      <span class="episode-duration">
                        <span class="sr-only">Durata:</span>
                        {station.data.podcast.duration}
                      </span>
                    )}
                  </div>
                )}

                {station.data.directions?.address && (
                  <p class="timeline-location">
                    <span class="sr-only">Indirizzo:</span>
                    {station.data.directions.address}
                  </p>
                )}

                <div class="timeline-actions">
                  <a href={`/stazioni/${station.id.replace(/\.md$/, '')}`} class="btn btn-primary">
                    Scopri la stazione
                  </a>
                  {station.data.directions?.mapsUrl && (
                    <a
                      href={station.data.directions.mapsUrl}
                      class="btn btn-outline"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Indicazioni
                      <span class="sr-only">(apre Google Maps in una nuova finestra)</span>
                    </a>
                  )}
                </div>
              </div>
            </article>

            {/* Connection hint to next station */}
            {index < sortedStations.length - 1 && (
              <div class="timeline-connector" aria-hidden="true">
                <span class="connector-text">
                  Prosegui verso la stazione {sortedStations[index + 1].data.order}
                </span>
              </div>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: var(--color-primary-50);
    padding: var(--space-12) 0;
    text-align: center;
  }

  .page-intro {
    max-width: 600px;
    margin: var(--space-4) auto 0;
    color: var(--color-neutral-600);
    font-size: var(--font-size-lg);
  }

  .stations-section {
    padding: var(--space-12) 0;
  }

  /* Timeline */
  .timeline {
    position: relative;
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 24px;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(
      to bottom,
      var(--color-primary-300),
      var(--color-secondary-300)
    );
    border-radius: var(--border-radius-full);
  }

  .timeline-item {
    position: relative;
    padding-left: 70px;
    padding-bottom: var(--space-8);
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-marker {
    position: absolute;
    left: 0;
    top: 0;
    width: 52px;
    height: 52px;
    background: var(--color-primary-500);
    border-radius: var(--border-radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-xl);
    box-shadow: var(--shadow-md);
    border: 4px solid white;
  }

  .timeline-content {
    overflow: hidden;
  }

  .timeline-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .timeline-title {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-2);
  }

  .timeline-title a {
    color: inherit;
    text-decoration: none;
  }

  .timeline-title a:hover {
    color: var(--color-primary-600);
  }

  .timeline-description {
    color: var(--color-neutral-600);
    margin-bottom: var(--space-3);
  }

  .timeline-meta {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
    font-size: var(--font-size-sm);
  }

  .episode-title {
    color: var(--color-accent-600);
    font-weight: var(--font-weight-medium);
  }

  .episode-duration {
    color: var(--color-neutral-500);
  }

  .timeline-location {
    font-size: var(--font-size-sm);
    color: var(--color-neutral-500);
    margin-bottom: var(--space-4);
  }

  .timeline-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .timeline-connector {
    margin-top: var(--space-6);
    padding-left: var(--space-4);
    border-left: 2px dashed var(--color-neutral-300);
    margin-left: calc(-70px + 26px);
    padding-top: var(--space-2);
    padding-bottom: var(--space-2);
  }

  .connector-text {
    font-size: var(--font-size-sm);
    color: var(--color-neutral-500);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .timeline::before {
      left: 16px;
    }

    .timeline-item {
      padding-left: 50px;
    }

    .timeline-marker {
      width: 36px;
      height: 36px;
      font-size: var(--font-size-base);
    }

    .timeline-connector {
      margin-left: calc(-50px + 18px);
    }
  }
</style>
