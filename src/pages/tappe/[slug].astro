---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StationDrawer from '../../components/StationDrawer.astro';
import DirectionsSection from '../../components/DirectionsSection.astro';
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';

export const prerender = true;

export async function getStaticPaths() {
  const tappe = await getCollection('tappe');
  return tappe.map((tappa) => ({
    params: { slug: tappa.id.replace(/\.md$/, '') },
    props: { tappa },
  }));
}

const { tappa } = Astro.props;
const { Content } = await render(tappa);

// Get all tappe for navigation
const allTappe = await getCollection('tappe', ({ data }) => data.published);
const sortedTappe = allTappe.sort((a, b) => a.data.order - b.data.order);

const { data } = tappa;

// Build the previous/current/next points for the directions mini-map.
const parseCoords = (c?: string): [number, number] | null => {
  if (!c) return null;
  const [lat, lng] = c.split(',').map((n) => parseFloat(n.trim()));
  return Number.isNaN(lat) || Number.isNaN(lng) ? null : [lat, lng];
};

const toPoint = (t: (typeof sortedTappe)[number]) => {
  const coords = parseCoords(t.data.directions?.coordinates);
  if (!coords) return null;
  return {
    order: t.data.order,
    title: t.data.title,
    slug: t.id.replace(/\.md$/, ''),
    lat: coords[0],
    lng: coords[1],
  };
};

const currentIndex = sortedTappe.findIndex((t) => t.data.order === data.order);
const currentPoint = toPoint(tappa);
const prevPoint = currentIndex > 0 ? toPoint(sortedTappe[currentIndex - 1]) : null;
const nextPoint =
  currentIndex >= 0 && currentIndex < sortedTappe.length - 1
    ? toPoint(sortedTappe[currentIndex + 1])
    : null;

// Parse markdown in transcript
const transcriptHtml = data.transcript ? await marked.parse(data.transcript) : null;

// Prepare gallery data for client-side script
const galleryJson = data.gallery ? JSON.stringify(data.gallery) : '[]';
---

<BaseLayout
  title={data.title}
  description={data.description}
>
  <article class="station-page">
    <!-- Hero / Gallery -->
    <header class="station-header">
      <div class="container">
        {data.gallery && data.gallery.length > 0 ? (
          <div class="gallery-hero" role="region" aria-label="Galleria immagini" data-gallery={galleryJson}>
            <div class="gallery-main">
              <button
                class="gallery-fullscreen-trigger"
                aria-label="Apri immagine a schermo intero"
                type="button"
              >
                <img
                  src={data.gallery[0].image}
                  alt={data.gallery[0].alt}
                  class="gallery-current-image"
                  id="gallery-main-image"
                />
              </button>
              <p class="gallery-caption" id="gallery-caption">
                {data.gallery[0].caption}
              </p>
            </div>
            {data.gallery.length > 1 && (
              <div class="gallery-nav">
                <button
                  class="gallery-btn gallery-prev"
                  aria-label="Immagine precedente"
                  data-direction="prev"
                  type="button"
                >
                  &#8592;
                </button>
                <span class="gallery-counter" aria-live="polite">
                  <span id="gallery-current">1</span> / {data.gallery.length}
                </span>
                <button
                  class="gallery-btn gallery-next"
                  aria-label="Immagine successiva"
                  data-direction="next"
                  type="button"
                >
                  &#8594;
                </button>
              </div>
            )}
            <div class="gallery-thumbnails" role="list">
              {data.gallery.map((img, index) => (
                <button
                  class:list={["gallery-thumb", { active: index === 0 }]}
                  data-index={index}
                  aria-label={`Vai all'immagine ${index + 1}: ${img.alt}`}
                  type="button"
                >
                  <img src={img.image} alt="" aria-hidden="true" />
                </button>
              ))}
            </div>
          </div>
        ) : data.heroImage ? (
          <img
            src={data.heroImage}
            alt=""
            class="hero-image"
          />
        ) : null}

        <div class="station-title-section">
          <span class="station-number" aria-label={`Tappa numero ${data.order}`}>
            {data.order}
          </span>
          <h1>{data.title}</h1>
        </div>
      </div>
    </header>

    <!-- Podcast Player -->
    {data.podcast && (
      <section class="podcast-section" aria-labelledby="podcast-heading">
        <div class="container">
          <div class="podcast-player">
            <div class="podcast-header">
              <span class="podcast-icon" aria-hidden="true">🎧</span>
              <div class="podcast-header-text">
                <h2 id="podcast-heading" class="podcast-eyebrow">Ascolta l'episodio</h2>
                {data.podcast.episodeTitle && (
                  <p class="podcast-title">{data.podcast.episodeTitle}</p>
                )}
                {data.podcast.duration && (
                  <p class="podcast-duration">
                    <span aria-hidden="true">⏱️</span> Durata: {data.podcast.duration}
                  </p>
                )}
              </div>
            </div>

            {/* Video Player (mp4) */}
            {data.podcast.videoFile && (
              <div class="video-player">
                <video
                  controls
                  preload="metadata"
                  playsinline
                  aria-label={`Video: ${data.podcast.episodeTitle || 'Episodio podcast'}`}
                >
                  <source src={data.podcast.videoFile} type="video/mp4" />
                  Il tuo browser non supporta l'elemento video.
                </video>
              </div>
            )}

            {/* MP3 Player */}
            {!data.podcast.videoFile && data.podcast.mp3File && (
              <div class="audio-player">
                <p class="audio-hint">
                  <span aria-hidden="true">▶</span> Premi play per ascoltare la storia di questa tappa
                </p>
                <audio
                  controls
                  preload="metadata"
                  aria-label={`Audio: ${data.podcast.episodeTitle || 'Episodio podcast'}`}
                >
                  <source src={data.podcast.mp3File} type="audio/mpeg" />
                  Il tuo browser non supporta l'elemento audio.
                </audio>
              </div>
            )}

            {(data.podcast.spotifyUrl || data.podcast.applePodcastsUrl) && (
              <div class="podcast-links">
                <span class="podcast-links-label">Oppure ascolta su:</span>
                {data.podcast.spotifyUrl && (
                  <a
                    href={data.podcast.spotifyUrl}
                    class="podcast-link spotify"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span aria-hidden="true">🎵</span> Spotify
                    <span class="sr-only">(apre in nuova finestra)</span>
                  </a>
                )}
                {data.podcast.applePodcastsUrl && (
                  <a
                    href={data.podcast.applePodcastsUrl}
                    class="podcast-link apple"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    <span aria-hidden="true"></span> Apple Podcasts
                    <span class="sr-only">(apre in nuova finestra)</span>
                  </a>
                )}
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- Tabs: Details / Transcript -->
    <div class="tabs-section">
      <div class="container">
        <div class="tabs" role="tablist" aria-label="Contenuti della tappa">
          <button
            role="tab"
            id="tab-details"
            aria-selected="true"
            aria-controls="panel-details"
            class="tab-button active"
          >
            Dettagli
          </button>
          <button
            role="tab"
            id="tab-transcript"
            aria-selected="false"
            aria-controls="panel-transcript"
            class="tab-button"
            tabindex="-1"
          >
            Trascrizione
          </button>
        </div>

        <!-- Details Tab -->
        <div
          role="tabpanel"
          id="panel-details"
          aria-labelledby="tab-details"
          class="tab-panel"
        >
          <div class="prose">
            <Content />
          </div>

          {data.directions && currentPoint && (
            <DirectionsSection
              directions={data.directions}
              current={currentPoint}
              prev={prevPoint}
              next={nextPoint}
            />
          )}
        </div>

        <!-- Transcript Tab -->
        <div
          role="tabpanel"
          id="panel-transcript"
          aria-labelledby="tab-transcript"
          class="tab-panel"
          hidden
        >
          <div class="transcript-content prose">
            <h2>Trascrizione del podcast</h2>
            <p class="transcript-intro">
              Questa trascrizione è stata creata per garantire l'accessibilità
              del contenuto audio a tutti gli utenti.
            </p>
            {/* Transcript content will come from the markdown body with specific section */}
            <Fragment set:html={transcriptHtml || '<p>Trascrizione in arrivo...</p>'} />
          </div>
        </div>
      </div>
    </div>

    <!-- Back to all stations -->
    <footer class="station-footer">
      <div class="container">
        <a href="/tappe" class="btn btn-outline">
          &#8592; Tutte le tappe
        </a>
      </div>
    </footer>
  </article>

  <!-- Station Navigation Drawer -->
  <StationDrawer stations={sortedTappe} currentStation={data.order} />

  <!-- Lightbox Modal -->
  {data.gallery && data.gallery.length > 0 && (
    <div
      class="lightbox"
      id="lightbox"
      role="dialog"
      aria-modal="true"
      aria-label="Galleria a schermo intero"
      hidden
    >
      <div class="lightbox-backdrop"></div>
      <div class="lightbox-content">
        <button
          class="lightbox-close"
          aria-label="Chiudi galleria"
          type="button"
        >
          &#10005;
        </button>
        <button
          class="lightbox-nav lightbox-prev"
          aria-label="Immagine precedente"
          data-direction="prev"
          type="button"
        >
          &#8592;
        </button>
        <figure class="lightbox-figure">
          <img
            src={data.gallery[0].image}
            alt={data.gallery[0].alt}
            class="lightbox-image"
            id="lightbox-image"
          />
          <figcaption class="lightbox-caption" id="lightbox-caption">
            {data.gallery[0].caption}
          </figcaption>
        </figure>
        <button
          class="lightbox-nav lightbox-next"
          aria-label="Immagine successiva"
          data-direction="next"
          type="button"
        >
          &#8594;
        </button>
        <span class="lightbox-counter" aria-live="polite">
          <span id="lightbox-current">1</span> / {data.gallery.length}
        </span>
      </div>
    </div>
  )}
</BaseLayout>

<script>
  // Tab functionality — scoped per tablist so independent groups (the main
  // Details/Transcript tabs and the "Come arrivare" mode selector) don't
  // interfere with each other.
  function setupTablist(tablist: Element) {
    const tabs = Array.from(tablist.querySelectorAll<HTMLElement>('[role="tab"]'));
    if (tabs.length === 0) return;

    function activateTab(tab: HTMLElement, setFocus = true) {
      tabs.forEach((t) => {
        const selected = t === tab;
        t.setAttribute('aria-selected', selected ? 'true' : 'false');
        t.tabIndex = selected ? 0 : -1;
        t.classList.toggle('active', selected);
        const panel = document.getElementById(t.getAttribute('aria-controls') || '');
        if (panel) panel.hidden = !selected;
      });
      if (setFocus) tab.focus();
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activateTab(tab));

      tab.addEventListener('keydown', (e) => {
        const key = (e as KeyboardEvent).key;
        let newTab: HTMLElement | null = null;
        const i = tabs.indexOf(tab);

        if (key === 'ArrowRight' || key === 'ArrowDown') {
          newTab = tabs[(i + 1) % tabs.length];
        } else if (key === 'ArrowLeft' || key === 'ArrowUp') {
          newTab = tabs[(i - 1 + tabs.length) % tabs.length];
        } else if (key === 'Home') {
          newTab = tabs[0];
        } else if (key === 'End') {
          newTab = tabs[tabs.length - 1];
        }

        if (newTab) {
          e.preventDefault();
          activateTab(newTab);
        }
      });
    });
  }

  // ---- Gallery + lightbox state ----
  // Module-scope so the single, persistent keydown handler below always reads
  // the current page's data. The page <script> module executes only once, but
  // setupStationPage() re-runs on every navigation via astro:page-load.
  let galleryData: any[] = [];
  let currentImageIndex = 0;
  let lightbox: HTMLElement | null = null;
  let lightboxTrigger: Element | null = null;

  function updateGallery(index: number, updateLightbox = false) {
    const mainImage = document.getElementById('gallery-main-image') as HTMLImageElement;
    const caption = document.getElementById('gallery-caption');
    const counter = document.getElementById('gallery-current');
    const thumbs = document.querySelectorAll('.gallery-thumb');

    if (mainImage && galleryData[index]) {
      mainImage.src = galleryData[index].image;
      mainImage.alt = galleryData[index].alt;
      if (caption) caption.textContent = galleryData[index].caption;
      if (counter) counter.textContent = String(index + 1);

      thumbs.forEach((thumb, i) => {
        thumb.classList.toggle('active', i === index);
      });

      currentImageIndex = index;

      // Also update lightbox if open
      if (updateLightbox) {
        updateLightboxImage(index);
      }
    }
  }

  function updateLightboxImage(index: number) {
    const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
    const lightboxCaption = document.getElementById('lightbox-caption');
    const lightboxCounter = document.getElementById('lightbox-current');

    if (lightboxImage && galleryData[index]) {
      lightboxImage.src = galleryData[index].image;
      lightboxImage.alt = galleryData[index].alt;
      if (lightboxCaption) lightboxCaption.textContent = galleryData[index].caption;
      if (lightboxCounter) lightboxCounter.textContent = String(index + 1);
    }
  }

  function openLightbox() {
    if (lightbox) {
      lightbox.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      updateLightboxImage(currentImageIndex);
      // Focus the close button for accessibility
      const closeBtn = lightbox.querySelector('.lightbox-close') as HTMLElement;
      closeBtn?.focus();
    }
  }

  function closeLightbox() {
    if (lightbox) {
      lightbox.setAttribute('hidden', '');
      document.body.style.overflow = '';
      // Return focus to the trigger
      (lightboxTrigger as HTMLElement)?.focus();
    }
  }

  // Wire up the page that just loaded. Re-runs on every client-side navigation;
  // every target is a fresh DOM node, so element listeners never accumulate.
  function setupStationPage() {
    // A previous page may have left the body scroll-locked (e.g. the lightbox
    // was open when the user navigated away via the drawer).
    document.body.style.overflow = '';

    document.querySelectorAll('[role="tablist"]').forEach(setupTablist);

    const galleryElement = document.querySelector('[data-gallery]');
    galleryData = galleryElement
      ? JSON.parse(galleryElement.getAttribute('data-gallery') || '[]')
      : [];
    currentImageIndex = 0;

    // Gallery navigation buttons
    document.querySelectorAll('.gallery-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const total = galleryData.length;
        if (!total) return;
        const direction = btn.getAttribute('data-direction');
        updateGallery(direction === 'next'
          ? (currentImageIndex + 1) % total
          : (currentImageIndex - 1 + total) % total);
      });
    });

    // Gallery thumbnails
    document.querySelectorAll('.gallery-thumb').forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const index = parseInt(thumb.getAttribute('data-index') || '0', 10);
        updateGallery(index);
      });
    });

    // Lightbox controls
    lightbox = document.getElementById('lightbox');
    lightboxTrigger = document.querySelector('.gallery-fullscreen-trigger');
    lightboxTrigger?.addEventListener('click', openLightbox);
    document.querySelector('.lightbox-close')?.addEventListener('click', closeLightbox);
    document.querySelector('.lightbox-backdrop')?.addEventListener('click', closeLightbox);

    document.querySelectorAll('.lightbox-nav').forEach((btn) => {
      btn.addEventListener('click', () => {
        const total = galleryData.length;
        if (!total) return;
        const direction = btn.getAttribute('data-direction');
        currentImageIndex = direction === 'next'
          ? (currentImageIndex + 1) % total
          : (currentImageIndex - 1 + total) % total;
        updateGallery(currentImageIndex);
        updateLightboxImage(currentImageIndex);
      });
    });
  }

  // Lightbox keyboard nav — registered once on document (which survives
  // navigations) and reads the module-scope state above, so it neither goes
  // stale nor accumulates duplicate handlers across navigations.
  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.hasAttribute('hidden')) return;
    const total = galleryData.length;
    if (e.key === 'Escape') {
      closeLightbox();
    } else if (e.key === 'ArrowRight' && total) {
      currentImageIndex = (currentImageIndex + 1) % total;
      updateGallery(currentImageIndex);
      updateLightboxImage(currentImageIndex);
    } else if (e.key === 'ArrowLeft' && total) {
      currentImageIndex = (currentImageIndex - 1 + total) % total;
      updateGallery(currentImageIndex);
      updateLightboxImage(currentImageIndex);
    }
  });

  document.addEventListener('astro:page-load', setupStationPage);
</script>

<style>
  .station-page {
    padding-bottom: var(--space-12);
  }

  /* Header */
  .station-header {
    background: var(--gradient-warm);
    padding-top: var(--space-6);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-primary-100);
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--border-radius-lg);
  }

  /* Gallery */
  .gallery-hero {
    margin-bottom: var(--space-6);
  }

  .gallery-main {
    position: relative;
  }

  .gallery-current-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--border-radius-lg);
  }

  .gallery-caption {
    text-align: center;
    padding: var(--space-3);
    background: var(--color-neutral-800);
    color: white;
    font-size: var(--font-size-sm);
    margin: 0;
    border-radius: 0 0 var(--border-radius-lg) var(--border-radius-lg);
    margin-top: -8px;
  }

  .gallery-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .gallery-btn {
    width: 44px;
    height: 44px;
    border-radius: var(--border-radius-full);
    background: var(--color-primary-500);
    color: white;
    font-size: var(--font-size-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
  }

  .gallery-btn:hover {
    background: var(--color-primary-600);
  }

  .gallery-counter {
    font-weight: var(--font-weight-medium);
  }

  .gallery-thumbnails {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    margin-top: var(--space-4);
    flex-wrap: wrap;
  }

  .gallery-thumb {
    width: 60px;
    height: 60px;
    border-radius: var(--border-radius-sm);
    overflow: hidden;
    border: 2px solid transparent;
    padding: 0;
    transition: all var(--transition-fast);
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-thumb.active,
  .gallery-thumb:hover {
    border-color: var(--color-primary-500);
  }

  /* Title section */
  .station-title-section {
    display: flex;
    align-items: center;
    gap: var(--space-5);
    margin-top: var(--space-6);
  }

  .station-number {
    width: 72px;
    height: 72px;
    background: linear-gradient(135deg, var(--color-primary-400), var(--color-primary-600));
    color: white;
    border-radius: var(--border-radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-family-heading);
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-bold);
    flex-shrink: 0;
    box-shadow: var(--shadow-primary);
    border: 3px solid white;
  }

  .station-title-section h1 {
    margin-bottom: 0;
  }

  /* Podcast section */
  .podcast-section {
    padding: var(--space-8) 0;
  }

  .podcast-player {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    background: var(--gradient-podcast);
    border: 1px solid var(--color-accent-200);
    border-radius: var(--border-radius-2xl);
    padding: var(--space-8);
    box-shadow: var(--shadow-md);
    max-width: 760px;
    margin: 0 auto;
  }

  .podcast-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .podcast-icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    background: white;
    border-radius: var(--border-radius-full);
    box-shadow: var(--shadow-sm);
  }

  .podcast-header-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .podcast-eyebrow {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent-700);
    margin: 0;
  }

  .podcast-title {
    font-family: var(--font-family-heading);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent-900);
    margin: 0;
    line-height: var(--line-height-tight);
  }

  .podcast-duration {
    font-size: var(--font-size-sm);
    color: var(--color-accent-700);
    margin: 0;
  }

  .audio-player {
    width: 100%;
    background: white;
    border-radius: var(--border-radius-lg);
    padding: var(--space-4);
    box-shadow: var(--shadow-sm);
  }

  .audio-hint {
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-medium);
    color: var(--color-accent-700);
    margin: 0 0 var(--space-3);
  }

  .audio-player audio {
    width: 100%;
  }

  .video-player {
    width: 100%;
  }

  .video-player video {
    width: 100%;
    border-radius: var(--border-radius-lg);
    background: black;
  }

  .podcast-links {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .podcast-links-label {
    font-size: var(--font-size-sm);
    color: var(--color-accent-700);
    font-weight: var(--font-weight-medium);
  }

  .podcast-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: white;
    border-radius: var(--border-radius-full);
    text-decoration: none;
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-sm);
    color: var(--color-neutral-700);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .podcast-link:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  /* Tabs */
  .tabs-section {
    padding: var(--space-8) 0;
  }

  /* Segmented pill control — horizontal, big tap targets */
  .tabs {
    display: inline-flex;
    flex-direction: row;
    gap: var(--space-2);
    padding: var(--space-2);
    margin-bottom: var(--space-8);
    background: var(--color-primary-100);
    border-radius: var(--border-radius-full);
    max-width: 100%;
  }

  .tab-button {
    flex: 1 1 auto;
    padding: var(--space-3) var(--space-8);
