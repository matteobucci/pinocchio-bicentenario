---
import BaseLayout from '../layouts/BaseLayout.astro';
import TourMap from '../components/TourMap.astro';
import { getCollection } from 'astro:content';
import mapPoints from '../content/settings/map-points.json';

// Get all published tappe sorted by order
const tappe = await getCollection('tappe', ({ data }) => data.published);
const sortedTappe = tappe.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="container">
      <h1 class="hero-title">Pinocchio Bicentenario</h1>
      <p class="hero-subtitle">Un viaggio in 12 tappe attraverso il mondo di Pinocchio</p>
      <p class="hero-intro">
        Benvenuti nel percorso del Bicentenario di Pinocchio tra Firenze e Sesto Fiorentino.
        Scoprite le 12 tappe che ripercorrono la storia del burattino più famoso del mondo,
        accompagnati dal nostro podcast accessibile a tutti.
      </p>
      <div class="hero-actions">
        <a href="/tappe" class="btn btn-primary">Esplora le tappe</a>
        <a href="/chi-siamo" class="btn btn-outline">Chi siamo</a>
      </div>
    </div>
  </section>

  <section class="map-preview" aria-labelledby="map-heading">
    <div class="container">
      <h2 id="map-heading">Il percorso sulla mappa</h2>
      <p class="section-intro">
        Le 12 tappe del percorso tra Firenze e Sesto Fiorentino, con i punti
        di servizio accessibili lungo il cammino.
      </p>
      <TourMap stations={sortedTappe} points={mapPoints.points} height="420px" />
    </div>
  </section>

  <section class="stations-preview" aria-labelledby="tappe-heading">
    <svg
      class="trail-bg"
      viewBox="0 0 1000 1000"
      preserveAspectRatio="none"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M 150 -30 C 150 130, 850 180, 850 340 C 850 500, 150 540, 150 700 C 150 860, 850 900, 850 1030" />
    </svg>
    <div class="container">
      <h2 id="tappe-heading">Le 12 Tappe</h2>
      <p class="section-intro">
        Ogni tappa racconta un capitolo della storia di Pinocchio, con podcast,
        immagini e trascrizioni accessibili.
      </p>

      <div class="stations-grid">
        {sortedTappe.map((tappa) => (
          <article class="station-card card">
            <a href={`/tappe/${tappa.id.replace(/\.md$/, '')}`} class="station-card-link">
              <div class="station-number" aria-hidden="true">{tappa.data.order}</div>
              <div class="card-body">
                <h3 class="station-title">{tappa.data.title}</h3>
                <p class="station-description">{tappa.data.description}</p>
                {tappa.data.podcast?.duration && (
                  <p class="station-meta">
                    <span class="sr-only">Durata podcast:</span>
                    {tappa.data.podcast.duration}
                  </p>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="section-action">
        <a href="/tappe" class="btn btn-secondary">
          Vedi tutte le tappe
        </a>
      </div>
    </div>
  </section>

  <section class="podcast-cta" aria-labelledby="podcast-heading">
    <div class="container">
      <h2 id="podcast-heading">Ascolta il Podcast</h2>
      <p>
        12 episodi che ti accompagnano attraverso il mondo di Pinocchio.
        Ogni episodio è disponibile direttamente sulla pagina della tappa,
        con la trascrizione completa per garantire l'accessibilità a tutti.
      </p>
      <div class="podcast-cta-actions">
        <a href="/tappe" class="btn btn-primary">Apri la prima tappa</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--gradient-hero);
    padding: var(--space-20) 0;
    text-align: center;
  }

  .hero-title {
    font-size: var(--font-size-5xl);
    color: var(--color-primary-700);
    margin-bottom: var(--space-4);
  }

  .hero-subtitle {
    font-size: var(--font-size-xl);
    color: var(--color-neutral-700);
    margin-bottom: var(--space-6);
  }

  .hero-intro {
    max-width: 600px;
    margin: 0 auto var(--space-8);
    font-size: var(--font-size-lg);
    line-height: var(--line-height-relaxed);
    color: var(--color-neutral-600);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Map Preview */
  .map-preview {
    padding: var(--space-16) 0 0;
  }

  /* Stations Preview */
  .stations-preview {
    position: relative;
    overflow: hidden;
    padding: var(--space-16) 0;
    background: var(--gradient-stations);
  }

  /* Decorative dashed trail winding behind the cards.
     preserveAspectRatio="none" stretches it to fill the section at any size;
     non-scaling-stroke keeps the dashes a uniform screen size so they never distort. */
  .trail-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    color: var(--color-primary-400);
    opacity: 0.35;
  }

  .trail-bg path {
    fill: none;
    stroke: currentColor;
    stroke-width: 4;
    stroke-linecap: round;
    stroke-dasharray: 14 20;
    vector-effect: non-scaling-stroke;
  }

  .stations-preview .container {
    position: relative;
    z-index: 1;
  }

  .section-intro {
    max-width: 600px;
    margin: 0 auto var(--space-8);
    text-align: center;
    color: var(--color-neutral-600);
  }

  .stations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .station-card {
    position: relative;
    /* allow the number badge to pop outside the rounded corner */
    overflow: visible;
    transition: transform var(--transition-fast), box-shadow var(--transition-fast);
  }

  .station-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  /* extra top room so the badge never collides with the title */
  .station-card .card-body {
    padding-top: var(--space-8);
  }

  .station-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .station-card-link:focus {
    outline: 2px solid var(--color-primary-500);
    outline-offset: 2px;
  }

  .station-number {
    position: absolute;
    top: -14px;
    left: -14px;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--color-primary-400), var(--color-primary-600));
    color: white;
    border-radius: var(--border-radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-family-heading);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-xl);
    box-shadow: var(--shadow-primary);
    border: 3px solid white;
    z-index: 2;
  }

  .station-title {
    color: var(--color-neutral-900);
  }

  .station-card:hover .station-title {
    color: var(--color-primary-600);
  }

  .station-description {
    color: var(--color-neutral-600);
    font-size: var(--font-size-sm);
    margin-bottom: var(--space-3);
  }

  .station-meta {
    font-size: var(--font-size-xs);
    color: var(--color-neutral-500);
  }

  .section-action {
    text-align: center;
  }

  /* Podcast CTA */
  .podcast-cta {
    background: var(--gradient-podcast);
    padding: var(--space-16) 0;
    text-align: center;
  }

  .podcast-cta h2 {
    color: var(--color-accent-700);
  }

  .podcast-cta p {
    max-width: 600px;
    margin: 0 auto var(--space-6);
    color: var(--color-neutral-600);
    line-height: var(--line-height-relaxed);
  }

  .podcast-cta-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: var(--font-size-3xl);
    }

    .hero-subtitle {
      font-size: var(--font-size-lg);
    }
  }
</style>
